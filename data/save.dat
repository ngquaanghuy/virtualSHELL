# virtualSHELL State File
# Do not edit manually

[ENVIRONMENT]
CLICOLOR=1
EDITOR=vim
GREP_OPTIONS=--color=auto
HISTFILE=/home/user/.history
HISTFILESIZE=1000
HISTSIZE=1000
HOME=/home/user
HOSTNAME=virtualshell
LANG=en_US.UTF-8
LS_OPTIONS=-F
PAGER=less
PATH=/bin:/usr/bin:/usr/local/bin
PWD=/home/user
SHELL=/bin/virtualsh
TERM=xterm-256color
USER=user
VISUAL=vim

[ALIASES]
l=ls -l
la=ls -a
ll=ls -la

[HISTORY]
