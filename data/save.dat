2026-03-14 10:30:09|1|cd /a
2026-03-14 10:30:10|0|ls
2026-03-14 10:30:11|1|cd a
2026-03-14 10:30:11|0|ls
2026-03-14 10:30:14|0|rm -rf *
2026-03-14 10:30:16|127|[A
2026-03-14 10:30:18|0|rm -rf *

[USER]
user=admin
hostname=myserver
